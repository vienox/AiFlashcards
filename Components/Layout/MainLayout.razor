@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="0" Dense="true" Class="appbar">
        <MudToolBar>
            <a href="/" class="app-title-link">AI Flashcards</a>
            <MudSpacer />
            <AuthorizeView>
                <Authorized Context="auth">
                    <div class="appbar-actions">
                        <MudText Typo="Typo.subtitle2" Class="appbar-user">@auth.User.Identity?.Name</MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Href="/logout" Class="appbar-button">
                            Logout
                        </MudButton>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="appbar-actions">
                        <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login" Class="appbar-button">
                            Log in
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Href="/register" Class="appbar-button">
                            Register
                        </MudButton>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </MudToolBar>
    </MudAppBar>
    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#ff7a3d",
            Secondary = "#1f7a8c",
            Background = "#f6f1e8",
            Surface = "#fffaf4",
            AppbarBackground = "#ff7a3d",
            TextPrimary = "#1c1b19",
            TextSecondary = "#6b5f54"
        },
    };
}
