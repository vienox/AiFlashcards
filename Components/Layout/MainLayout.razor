@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="0" Dense="true">
        <MudText Typo="Typo.h6" Class="app-title">AI Flashcards</MudText>
    </MudAppBar>
    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        Palette = new Palette
        {
            Primary = "#ff7a3d",
            Secondary = "#1f7a8c",
            Background = "#f6f1e8",
            Surface = "#fffaf4",
            AppbarBackground = "#ff7a3d",
            TextPrimary = "#1c1b19",
            TextSecondary = "#6b5f54"
        },
        Typography = new Typography
        {
            Default = new Default
            {
                FontFamily = new[] { "Trebuchet MS", "Verdana", "Tahoma", "sans-serif" },
                FontSize = "0.95rem"
            },
            H1 = new H1
            {
                FontFamily = new[] { "Palatino Linotype", "Book Antiqua", "Palatino", "serif" },
                FontWeight = 700,
                FontSize = "2.6rem",
                LineHeight = 1.2
            },
            H2 = new H2
            {
                FontFamily = new[] { "Palatino Linotype", "Book Antiqua", "Palatino", "serif" },
                FontWeight = 700,
                FontSize = "2.1rem",
                LineHeight = 1.25
            }
        }
    };
}
