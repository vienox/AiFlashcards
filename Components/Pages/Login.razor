@page "/login"
@attribute [AllowAnonymous]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.JSInterop

<PageTitle>Log in</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="page-shell">
    <MudPaper Class="panel" Elevation="6">
        <MudText Typo="Typo.h5">Log in</MudText>
        <MudText Typo="Typo.body2" Class="muted">Use your account to access flashcards.</MudText>

        @if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4" Icon="@Icons.Material.Filled.Error">
                @ErrorMessage
            </MudAlert>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />

            <MudTextField Label="Username"
                          @bind-Value="_model.UserName"
                          Variant="Variant.Outlined"
                          Class="field-gap" />
            <MudTextField Label="Password"
                          @bind-Value="_model.Password"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="field-gap" />
            <MudCheckBox T="bool" @bind-Value="_model.RememberMe" Label="Remember me" />

            <div class="action-row">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Disabled="@IsBusy">
                    @(IsBusy ? "Signing in..." : "Log in")
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="GoToRegister" ButtonType="ButtonType.Button" Disabled="@IsBusy">
                    Create account
                </MudButton>
            </div>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private readonly LoginModel _model = new();
    private string? ErrorMessage { get; set; }
    private bool IsBusy { get; set; }

    [Inject] public NavigationManager NavigationManager { get; set; } = default!;
    [Inject] public IJSRuntime JSRuntime { get; set; } = default!;
    [CascadingParameter] private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
        }
    }

    private async Task HandleLoginAsync()
    {
        if (IsBusy)
        {
            return;
        }

        ErrorMessage = null;
        IsBusy = true;

        try
        {
            var formData = new Dictionary<string, string>
            {
                ["UserName"] = _model.UserName.Trim(),
                ["Password"] = _model.Password,
                ["RememberMe"] = _model.RememberMe.ToString(),
                ["ReturnUrl"] = GetSafeReturnUrl()
            };

            await JSRuntime.InvokeVoidAsync("submitLoginForm", formData);
        }
        catch (JSException jsEx)
        {
            // Extract clean error message from JS exception
            var message = jsEx.Message ?? "Login failed. Please try again.";
            message = message.Replace("Error: ", "");
            
            // Remove stack trace (anything after " at ")
            var atIndex = message.IndexOf(" at ");
            if (atIndex > 0)
            {
                message = message.Substring(0, atIndex).Trim();
            }
            
            // Remove duplicate sentences
            var sentences = message.Split(new[] { ". " }, StringSplitOptions.RemoveEmptyEntries);
            if (sentences.Length > 1)
            {
                // Check if first sentence is repeated
                var uniqueSentences = new List<string>();
                foreach (var sentence in sentences)
                {
                    if (!uniqueSentences.Contains(sentence))
                    {
                        uniqueSentences.Add(sentence);
                    }
                }
                message = string.Join(". ", uniqueSentences);
                if (!message.EndsWith("."))
                {
                    message += ".";
                }
            }
            
            ErrorMessage = message;
        }
        catch (Exception)
        {
            ErrorMessage = "Login failed. Please try again.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void GoToRegister()
    {
        var returnUrl = Uri.EscapeDataString(GetSafeReturnUrl());
        NavigationManager.NavigateTo($"/register?returnUrl={returnUrl}");
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/";
        }

        return ReturnUrl.StartsWith("/") ? ReturnUrl : "/";
    }

    private sealed class LoginModel
    {
        [Required]
        public string UserName { get; set; } = string.Empty;

        [Required]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
