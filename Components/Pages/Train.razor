@page "/train"
<PageTitle>Train</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="train-shell">
    <MudText Typo="Typo.h4">Training</MudText>
    <MudText Typo="Typo.body2" Class="muted">Click the card to flip it.</MudText>

    @if (!TrainingState.HasCards)
    {
        <MudPaper Class="placeholder" Elevation="0">
            No flashcards loaded. Generate cards first.
        </MudPaper>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
            Back to generator
        </MudButton>
    }
    else
    {
        <div class="train-meta">
            <MudText Typo="Typo.subtitle2">Card @(TrainingState.CurrentIndex + 1) of @TrainingState.Cards.Count</MudText>
        </div>

        <div class="flip-card @(IsFlipped ? "is-flipped" : "")" @onclick="ToggleFlip">
            <div class="flip-card__inner">
                <div class="flip-card__face flip-card__front">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Question</MudText>
                        <MudText Typo="Typo.h6">@TrainingState.CurrentCard?.Front</MudText>
                    </MudPaper>
                </div>
                <div class="flip-card__face flip-card__back">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Answer</MudText>
                        <MudText Typo="Typo.h6">@TrainingState.CurrentCard?.Back</MudText>
                    </MudPaper>
                </div>
            </div>
        </div>

        <div class="train-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Previous">
                Previous
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ToggleFlip">
                Flip
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Next">
                Next
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Shuffle">
                Shuffle
            </MudButton>
        </div>
    }
</MudContainer>
