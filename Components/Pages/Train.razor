@page "/train"
<PageTitle>Train</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="train-shell">
    <div class="train-top">
        <div>
            <MudText Typo="Typo.h4">Training</MudText>
            <MudText Typo="Typo.body2" Class="muted">Tap the card or press Flip.</MudText>
        </div>
        @if (TrainingState.HasCards)
        {
            <div class="train-count">
                Card @(TrainingState.CurrentIndex + 1) / @TrainingState.Cards.Count
            </div>
        }
    </div>

    @if (!TrainingState.HasCards)
    {
        <MudPaper Class="placeholder" Elevation="0">
            No flashcards loaded. Generate cards first.
        </MudPaper>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
            Back to generator
        </MudButton>
    }
    else
    {
        <MudProgressLinear Value="@Progress" Color="Color.Secondary" Class="train-progress" />

        <div id="training-card" class="flip-card @(IsFlipped ? "is-flipped" : "")" @ref="CardRef" @onclick="FlipCardAsync">
            <div class="flip-card__inner">
                <div class="flip-card__face flip-card__front">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Question</MudText>
                        <MudText Typo="Typo.h6" Class="train-text" data-autosize="true">
                            @TrainingState.CurrentCard?.Front
                        </MudText>
                    </MudPaper>
                </div>
                <div class="flip-card__face flip-card__back">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Answer</MudText>
                        <MudText Typo="Typo.h6" Class="train-text" data-autosize="true">
                            @TrainingState.CurrentCard?.Back
                        </MudText>
                    </MudPaper>
                </div>
            </div>
        </div>

        <div class="train-actions">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Previous">
                Previous
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FlipCardAsync">
                Flip
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Next">
                Next
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Shuffle">
                Shuffle
            </MudButton>
        </div>
    }
</MudContainer>
