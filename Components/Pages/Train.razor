@page "/train"
@attribute [Authorize]
<PageTitle>Train</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="train-shell">
    <div class="train-top">
        <div>
            <MudText Typo="Typo.h4">Training</MudText>
            <MudText Typo="Typo.body2" Class="muted">Tap the card or press Flip.</MudText>
        </div>
        @if (TrainingState.HasCards)
        {
            <div class="train-count">
                <div>Card @(TrainingState.CurrentIndex + 1) / @TrainingState.Cards.Count</div>
                <div style="color: #4caf50; font-weight: 500;">✓ Correct: @TrainingState.CorrectCount / @TrainingState.TotalCardsAtStart</div>
            </div>
        }
    </div>

    @if (!TrainingState.HasCards)
    {
        <MudPaper Class="placeholder" Elevation="0">
            No flashcards loaded. Generate cards first.
        </MudPaper>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoBack">
            Back to generator
        </MudButton>
    }
    else
    {
        <MudProgressLinear Value="@Progress" Color="Color.Secondary" Class="train-progress" />

        <div id="training-card" class="flip-card @(IsFlipped ? "is-flipped" : "")" @ref="CardRef" @onclick="FlipCardAsync">
            <div class="flip-card__inner">
                <div class="flip-card__face flip-card__front">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Question</MudText>
                        <MudText Typo="Typo.h6" Class="train-text" data-autosize="true">
                            @TrainingState.CurrentCard?.Front
                        </MudText>
                    </MudPaper>
                </div>
                <div class="flip-card__face flip-card__back">
                    <MudPaper Class="train-card" Elevation="6">
                        <MudText Typo="Typo.subtitle2" Class="card-label">Answer</MudText>
                        <MudText Typo="Typo.h6" Class="train-text" data-autosize="true">
                            @TrainingState.CurrentCard?.Back
                        </MudText>
                    </MudPaper>
                </div>
            </div>
        </div>

        @if (!ShowingResults)
        {
            <div class="train-actions">
                @if (!IsFlipped)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Previous" Class="train-btn train-btn--ghost">
                        Previous
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="FlipCardAsync" Class="train-btn train-btn--primary">
                        Flip
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="Next" Class="train-btn train-btn--ghost">
                        Next
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="MarkCorrect" Class="train-btn" Style="flex: 1;">
                        ✓ Correct
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="MarkWrong" Class="train-btn" Style="flex: 1;">
                        ✗ Wrong
                    </MudButton>
                }
            </div>
            <div style="text-align: center; margin-top: 1rem;">
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="Shuffle" Class="train-btn train-btn--text">
                    Shuffle
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="GoBack" Class="train-btn train-btn--text">
                    Back to Home
                </MudButton>
            </div>
        }
        else
        {
            <MudPaper Class="placeholder" Elevation="0" Style="text-align: center; padding: 3rem;">
                <MudText Typo="Typo.h5" Style="margin-bottom: 1rem;">🎉 Session Complete!</MudText>
                <MudText Typo="Typo.body1" Style="margin-bottom: 0.5rem;">
                    Correct: @TrainingState.CorrectCount / @TrainingState.TotalCardsAtStart
                </MudText>
                @if (TrainingState.HasWrongCards)
                {
                    <MudText Typo="Typo.body2" Style="color: #f44336; margin-bottom: 2rem;">
                        Wrong cards: @TrainingState.WrongCardsCount
                    </MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ReplayWrongCards" Style="margin-right: 1rem;">
                        Replay Wrong Cards
                    </MudButton>
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="color: #4caf50; margin-bottom: 2rem;">
                        Perfect score! 🌟
                    </MudText>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="GoBack">
                    Back to Generator
                </MudButton>
            </MudPaper>
        }
    }
</MudContainer>
