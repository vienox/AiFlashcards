@page "/"
<PageTitle>AI Flashcards</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="page-shell">
    <MudGrid Class="hero-grid" Spacing="4">
        <MudItem xs="12" md="6">
            <MudPaper Class="hero-copy" Elevation="0">
                <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Class="badge-chip">
                    AI FLASHCARDS
                </MudChip>
                <MudText Typo="Typo.h2">AI flashcards from your materials</MudText>
                <MudText Typo="Typo.body1" Class="hero-lead">
                    Paste text, drop in a PDF or TXT, and generate flashcards in seconds.
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="panel" Elevation="6">
                <MudText Typo="Typo.h6">Source</MudText>
                <MudTextField Label="Account name"
                              @bind-Value="AccountName"
                              Variant="Variant.Outlined"
                              Class="field-gap" />
                <MudSelect T="InputModeKind"
                           Label="Mode"
                           @bind-Value="InputMode"
                           Variant="Variant.Outlined"
                           Class="field-gap">
                    <MudSelectItem Value="InputModeKind.Text">Text</MudSelectItem>
                    <MudSelectItem Value="InputModeKind.File">File</MudSelectItem>
                </MudSelect>

                @if (InputMode == InputModeKind.Text)
                {
                    <MudTextField Label="Paste text"
                                  @bind-Value="SourceText"
                                  Lines="7"
                                  Variant="Variant.Outlined" />
                }
                else
                {
                    <MudText Typo="Typo.subtitle2" Class="field-gap">
                        Choose a file (PDF, TXT, MD, CSV)
                    </MudText>
                    <InputFile OnChange="OnFileSelected"
                               accept=".pdf,.txt,.md,.csv"
                               class="file-input" />
                    <MudText Typo="Typo.caption" Class="file-meta">@FileLabel</MudText>
                }

                <div class="count-row">
                    <MudText Typo="Typo.subtitle2">Number of cards</MudText>
                    <MudSlider @bind-Value="CardCount" Min="4" Max="24" Step="1" Color="Color.Secondary" />
                    <MudText Typo="Typo.subtitle2" Class="count-value">@CardCount</MudText>
                </div>

                <div class="action-row">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateAsync" Disabled="@IsBusy">
                        @(IsBusy ? "Generating..." : "Generate flashcards")
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick="ClearAll" Disabled="@IsBusy">
                        Clear
                    </MudButton>
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="alert-gap">
                        @ErrorMessage
                    </MudAlert>
                }
                @if (!string.IsNullOrWhiteSpace(InfoMessage))
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="alert-gap">
                        @InfoMessage
                    </MudAlert>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudDivider Class="section-divider" />

    <div class="results-head">
        <MudText Typo="Typo.h5">Results</MudText>
        <MudText Typo="Typo.caption" Class="muted">Your generated flashcards</MudText>
        @if (Cards.Count > 0)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="GoToTraining">
                Start training
            </MudButton>
        }
    </div>

    @if (IsBusy)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="progress" />
    }
    else if (Cards.Count == 0)
    {
        <MudPaper Class="placeholder" Elevation="0">
            Your flashcards will appear here after generation.
        </MudPaper>
    }
    else
    {
        <MudGrid Spacing="3" Class="cards-grid">
            @foreach (var card in Cards)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Class="flashcard" Elevation="4">
                        <MudText Typo="Typo.subtitle2" Class="card-front">@card.Front</MudText>
                        <MudText Typo="Typo.body2">@card.Back</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>
